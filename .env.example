# ============================================================================
# GOAT UGC AI — environment configuration
# Copy to .env.local for development; set the same vars in Vercel for prod.
# ============================================================================

# Which provider to use: fal | muapi | local
# Omit to auto-detect from whichever key is present.
AI_PROVIDER=fal

# ---- fal.ai (default cloud) ------------------------------------------------
# Sign up at https://fal.ai and create a key: https://fal.ai/dashboard/keys
FAL_KEY=

# ---- Muapi.ai (powers /studio — the full Open Generative AI experience) ---
# Optional. If set, the Pro Studio proxy will fall back to this shared key when
# a visitor hasn't brought their own. Otherwise users enter their key on first
# visit (BYOK).
MUAPI_KEY=

# ---- Local runtime (self-host your own GPU box) ----------------------------
# Point at your Ollama / ComfyUI / sd.cpp HTTP endpoint. See lib/providers/local.js
# for the exact request shape the adapter sends.
LOCAL_INFERENCE_URL=
