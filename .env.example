# ============================================================================
# GOAT UGC AI — environment configuration
# Copy to .env.local for development; set the same vars in Vercel for prod.
# Do NOT commit .env.local — it's already in .gitignore.
# ============================================================================

# ---- Provider selection ---------------------------------------------------
# Which provider to use: fal | local. Omit to auto-detect.
AI_PROVIDER=fal

# ---- fal.ai (default cloud) -----------------------------------------------
# Sign up at https://fal.ai and create a key:
#   https://fal.ai/dashboard/keys
FAL_KEY=

# Optional: which fal.ai any-llm model to use for scene planning.
# Defaults to openai/gpt-4o-mini (cheap, reliable structured output).
# FAL_LLM_MODEL=openai/gpt-4o-mini

# ---- Local runtime (self-host on your own GPU box) ------------------------
# Point at your Ollama / ComfyUI / sd.cpp HTTP endpoint. See
# lib/providers/local.js for the exact request shape.
# LOCAL_INFERENCE_URL=http://127.0.0.1:7860
